# STRATIVY BRAIN — OpenRouter API key (local server + production static builds).
# Model: liquid/lfm-2.5-1.2b-instruct:free (@openrouter/sdk → https://openrouter.ai/api/v1)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: injected into static GitHub Pages build (same value as OPENROUTER_API_KEY in CI).
# VITE_OPENROUTER_API_KEY=

# STRATIVY BRAIN presentation mode — curated static insights, no live API calls.
# Defaults to true when unset (safe for demos and GitHub Pages).
# Set to false to enable live OpenRouter analysis (requires OPENROUTER_API_KEY above).
VITE_STRATIVY_BRAIN_STATIC=true

# Deprecated (Gemini disabled):
# GEMINI_API_KEY=
# MONEY_FLOW_GEMINI_API=
# VITE_GEMINI_API_KEY=

# Optional: public URL when hosted.
APP_URL="http://localhost:3000"
