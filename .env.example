# Required for Gemini AI board advisor API calls.
MONEY_FLOW_GEMINI_API="your_gemini_api_key_here"

# Gemini model (default: gemini-2.5-flash). Use a model enabled on your API tier.
# If you see "limit: 0" quota errors, switch models or enable billing in Google AI Studio.
GEMINI_MODEL="gemini-2.5-flash"

# Optional: public URL when hosted (OAuth callbacks, self-referential links).
APP_URL="http://localhost:3000"
